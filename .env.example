# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control!

# Application
APP_NAME="AI Conversational Chatbot"
DEBUG=true
SECRET_KEY="your-secret-key-change-this"

# Database (PostgreSQL - use same values as in docker-compose)
DATABASE_URL="postgresql+asyncpg://chatbot:chatbot@localhost:5432/chatbot_db"
DATABASE_URL_SYNC="postgresql://chatbot:chatbot@localhost:5432/chatbot_db"

# Redis
REDIS_URL="redis://localhost:6379/0"

# LLM Configuration
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
HUGGINGFACE_TOKEN=""

# LLaMA Model (if using local model)
LLAMA_MODEL_PATH="./models/llama-2-7b-chat.gguf"

# Vector Database (Weaviate)
WEAVIATE_URL="http://localhost:8080"
WEAVIATE_API_KEY=""

# Pinecone
PINECONE_API_KEY=""
PINECONE_ENVIRONMENT=""
PINECONE_INDEX_NAME="chatbot-knowledge"

# Elasticsearch
ELASTICSEARCH_URL="http://localhost:9200"

# Session
SESSION_SECRET="your-session-secret"
SESSION_EXPIRE_MINUTES=1440

# Logging
LOG_LEVEL="INFO"
